generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id    String  @id @default(uuid()) @db.Uuid
  code  String  @unique
  name  String
  value Decimal @db.Decimal(15, 2)

  // Explicit many-to-many relationship
  rawMaterials ProductRawMaterial[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("products")
  @@index([code])
}

model RawMaterial {
  id            String  @id @default(uuid()) @db.Uuid
  code          String  @unique
  name          String
  stockQuantity Decimal @db.Decimal(15, 4)

  // Explicit many-to-many relationship
  products ProductRawMaterial[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("raw_materials")
  @@index([code])
}

model ProductRawMaterial {
  productId     String   @db.Uuid
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  rawMaterialId String      @db.Uuid
  rawMaterial   RawMaterial @relation(fields: [rawMaterialId], references: [id], onDelete: Restrict)
  
  requiredQuantity Decimal @db.Decimal(15, 4)

  @@id([productId, rawMaterialId])
  @@index([productId])
  @@index([rawMaterialId])
  @@map("product_raw_materials")
}
